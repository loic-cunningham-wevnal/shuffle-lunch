# Local dev: copy to .env.local and fill in values.
# Production: set these in Vercel → Settings → Environment Variables.

# Password required to sign into the app. Pick something long and random.
APP_PASSWORD=change-me

# HMAC secret used to sign session cookies. Generate one with:
#   openssl rand -hex 32
# Must be at least 32 characters. Rotating this invalidates all sessions.
AUTH_SECRET=

# Vercel Blob storage token. Required for the deployed app to read members /
# enrichment / history data and required by `bun cli/cmd/index.ts blob-sync`
# to upload your local data files. In a Vercel project with Blob storage
# attached, this is set automatically — pull it locally with:
#   vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=
